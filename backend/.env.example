# Example backend environment file (DO NOT commit secrets here)
# Copy this to backend/.env and set real values before running locally.

# API keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Application data directory (relative to project root or absolute)
APP_DATA_DIR=data

# SMTP settings (use app password where appropriate)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=you@example.com
SENDER_PASSWORD=change_me
